# Pytest temp directories (generated by test runs, never commit)
.pytest-tmp*/
.pytest_tmp*/
.pytest_temp*/

# Runtime data (generated per-installation, never commit)
kazma-data/
swarm_registry.json

# Machine-local config overrides (never commit — use Settings UI or this file)
# Shipped defaults stay in tracked kazma.yaml; edit this for local ports/tokens.
kazma.local.yaml
*.local.yaml

# SQLite WAL/SHM files (transient, never commit)
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# Kubernetes secrets (never commit credentials)
kubernetes/*secrets*.yaml

# ZCode internal artifacts
.zcode/
.keys/
