# Kazma Environment Variables
# Copy to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────
# Default port is 9090 (CLI + kazma.yaml). Windows may block 9090; use
# another free port if bind fails (e.g. 9091).
# KAZMA_PORT=9090
# KAZMA_HOST=127.0.0.1
# Bind 0.0.0.0 only behind a reverse proxy with real auth.
# KAZMA_WORKSPACE=G:/path/to/your/repo

# ── Platform connectors ─────────────────────────────────────────────
# Telegram Bot API token (required for Telegram adapter)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot token (optional, for Discord adapter)
DISCORD_BOT_TOKEN=

# Slack Bot token (optional, for Slack adapter)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── LLM keys ────────────────────────────────────────────────────────
# Generic fallbacks read by the LLM provider layer:
OPENAI_API_KEY=
KAZMA_API_KEY=
# Active model/provider (optional overrides):
# KAZMA_PROVIDER=openai
# KAZMA_MODEL=gpt-4o-mini
#
# NOTE: DEEPSEEK_API_KEY / ANTHROPIC_API_KEY are NOT read by core code.
# Configure DeepSeek/Anthropic/etc. via Settings → Providers (ConfigStore)
# or the provider list in the UI — not dedicated env vars.

# Google Cloud / Vertex AI (optional — uses ADC, no API key needed)
# Set GOOGLE_CLOUD_PROJECT if ADC doesn't have a default project
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Swarm bot (optional, for dedicated swarm output bot)
SWARM_BOT_TOKEN=
SWARM_CHAT_ID=

# ── Auth / security ─────────────────────────────────────────────────
# Shared secret for sensitive API routes. Auto-generated on loopback if
# unset. Non-loopback bind (0.0.0.0) REQUIRES an explicit strong secret.
# Cookie auto-issued for loopback only; set KAZMA_TRUST_LAN=1 for LAN labs.
# KAZMA_SECRET=your-strong-random-secret-here
# KAZMA_TRUST_LAN=0
# Optional HS256 secret for verified multi-tenant JWT claims:
# KAZMA_JWT_SECRET=

# Production profile (Docker compose sets PRODUCTION=1 by default):
#   - Forces Docker jail for python_exec (no local fallback)
#   - Disables YOLO unless KAZMA_ALLOW_YOLO=1
#   - Stricter shell allowlist
# KAZMA_PRODUCTION=1
# KAZMA_ALLOW_YOLO=0
# KAZMA_CODE_EXEC_DOCKER=force
# KAZMA_WORKSPACE_ROOT=/data/workspaces
# KAZMA_ALLOW_PRIVATE_LLM=0
# KAZMA_PUBLIC_URL=https://your.domain
# Opaque browser sessions (default on) — cookie is random id, not the secret
# KAZMA_OPAQUE_SESSIONS=1
# KAZMA_SESSION_TTL_SECONDS=1209600
# KAZMA_TURN_TIMEOUT_SECONDS=600
# KAZMA_MCP_SAFE_ALLOWLIST=read_file,list_dir
# KAZMA_SEMANTIC_CACHE_TTL_SECONDS=86400
# KAZMA_SEMANTIC_CACHE_MAX_ROWS=10000

# ── Multi-replica / Postgres (Phase 4.3) ────────────────────────────
# Do NOT share SQLite files across replicas. Use Postgres instead:
# KAZMA_DATABASE_URL=postgresql://kazma:pass@db:5432/kazma
# KAZMA_DB_BACKEND=postgres
# KAZMA_PG_POOL_MIN=1
# KAZMA_PG_POOL_MAX=10
# pip install -e ".[postgres]"

# ── Multi-user / OIDC (Phase 4.4) ───────────────────────────────────
# KAZMA_MULTI_USER=1
# Local users are stored under ConfigStore key platform.users
# OIDC (optional):
# KAZMA_OIDC_ISSUER=https://accounts.example.com
# KAZMA_OIDC_CLIENT_ID=
# KAZMA_OIDC_CLIENT_SECRET=
# KAZMA_OIDC_REDIRECT_URI=https://your.domain/api/auth/oidc/callback
# KAZMA_OIDC_DEFAULT_ROLE=operator

# Encrypted Secret Vault (auto-generated on first startup if not set)
# Required for production: secrets stay out of plaintext settings.db
# KAZMA_VAULT_KEY=your-vault-encryption-key-here

# ── Vector memory / embeddings ──────────────────────────────────────
# KAZMA_VECTOR_PATH=~/.kazma/vector_memory
# KAZMA_VECTOR_COLLECTION=agent_memory
# KAZMA_VECTOR_MODEL=all-MiniLM-L6-v2
# NVIDIA NIM / OpenAI-compatible embeddings (see kazma.yaml memory.embedding):
# KAZMA_EMBED_API_KEY=nvapi-xxxxxxxx

# ── Git bot identity (optional) ─────────────────────────────────────
# KAZMA_BOT_NAME=Kazma Agent
# KAZMA_BOT_EMAIL=kazma-agent[bot]@users.noreply.github.com

# ── GitHub (optional) ───────────────────────────────────────────────
# Option A — OAuth App ("Connect GitHub" button on Workspace):
#   1. https://github.com/settings/developers → New OAuth App
#   2. Authorization callback URL must match your host, e.g.:
#        http://127.0.0.1:9090/api/github/oauth/callback
#        http://172.x.x.x:9090/api/github/oauth/callback   (if using LAN IP)
#   3. Paste Client ID + Client secret here, restart Kazma.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
#
# Option B — Personal Access Token (no OAuth App; paste on Workspace page):
#   https://github.com/settings/tokens  (classic, scope: repo)
# GITHUB_TOKEN=

# ── code_exec sandbox ───────────────────────────────────────────────
# Prefer Docker jail when docker CLI is available (network=none, memory cap).
# auto | 1 | 0   (default: auto)
# KAZMA_CODE_EXEC_DOCKER=auto
# Image used for the jail (must include python):
# KAZMA_CODE_EXEC_IMAGE=python:3.12-slim

