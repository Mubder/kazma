# Kazma Environment Variables
# Copy to .env and fill in your values

# Telegram Bot API token (required for Telegram adapter)
TELEGRAM_BOT_TOKEN=your_*...n
# Discord Bot token (optional, for Discord adapter)
DISCORD_BOT_TOKEN=*** LLM Provider API keys
DEEPSEEK_API_KEY=
OPEN...# HITL shared secret (optional — if set, /api/approve requires X-Kazma-Secret header)
# KAZMA_SECRET=your-secret-*** Vector memory path (optional — default: ~/.kazma/vector_memory)
# KAZMA_VECTOR_PATH=~/.kazma/vector_memory
# KAZMA_VECTOR_COLLECTION=agent_memory
# KAZMA_VECTOR_MODEL=all-MiniLM-L6-v2
