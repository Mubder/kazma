# Kazma Environment Variables
# Copy to .env and fill in your values

# Telegram Bot API token (required for Telegram adapter)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot token (optional, for Discord adapter)
DISCORD_BOT_TOKEN=

# Slack Bot token (optional, for Slack adapter)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# LLM Provider API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Google Cloud / Vertex AI (optional — uses ADC, no API key needed)
# Set GOOGLE_CLOUD_PROJECT if ADC doesn't have a default project
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Swarm bot (optional, for dedicated swarm output bot)
SWARM_BOT_TOKEN=
SWARM_CHAT_ID=

# HITL shared secret (optional — if set, /api/approve requires X-Kazma-Secret header)
# KAZMA_SECRET=your-secret-here

# Encrypted Secret Vault (auto-generated on first startup if not set)
# The vault lets the agent securely store and retrieve secrets (API keys, tokens, passwords)
# KAZMA_VAULT_KEY=your-vault-encryption-key-here

# Vector memory path (optional — default: ~/.kazma/vector_memory)
# KAZMA_VECTOR_PATH=~/.kazma/vector_memory
# KAZMA_VECTOR_COLLECTION=agent_memory
# KAZMA_VECTOR_MODEL=all-MiniLM-L6-v2
