# Kazma Environment Variables
# Copy to .env and fill in your values

# Telegram Bot API token (required for Telegram adapter)
TELEGRAM_BOT_TOKEN=your_***_token_here

# Discord Bot token (optional, for Discord adapter)
DISCORD_BOT_TOKEN=

# LLM Provider API keys
DEEPSEEK_API_KEY=your_deepseek_key_here
OPEN...
