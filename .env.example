# Kazma Environment Variables
# Copy to .env and fill in your values

# Telegram Bot API token (required for Telegram adapter)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot token (optional, for Discord adapter)
DISCORD_BOT_TOKEN=

# Slack Bot token (optional, for Slack adapter)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# LLM Provider API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Google Cloud / Vertex AI (optional — uses ADC, no API key needed)
# Set GOOGLE_CLOUD_PROJECT if ADC doesn't have a default project
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Swarm bot (optional, for dedicated swarm output bot)
SWARM_BOT_TOKEN=
SWARM_CHAT_ID=

# HITL shared secret (optional — if set, /api/approve requires X-Kazma-Secret header)
# KAZMA_SECRET=your-secret-here

# Encrypted Secret Vault (auto-generated on first startup if not set)
# The vault lets the agent securely store and retrieve secrets (API keys, tokens, passwords)
# KAZMA_VAULT_KEY=your-vault-encryption-key-here

# Vector memory path (optional — default: ~/.kazma/vector_memory)
# KAZMA_VECTOR_PATH=~/.kazma/vector_memory
# KAZMA_VECTOR_COLLECTION=agent_memory
# KAZMA_VECTOR_MODEL=all-MiniLM-L6-v2

# Embedding backend (optional — default: local sentence-transformers)
# To use NVIDIA NIM / NeMo Retriever or any OpenAI-compatible endpoint:
# KAZMA_EMBED_PROVIDER=openai-compatible
# KAZMA_EMBED_MODEL=nvidia/nv-embed-v1
# KAZMA_EMBED_DIM=1024
# KAZMA_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
# KAZMA_EMBED_API_KEY=nvapi-xxxxxxxx

# Bot commit identity (optional — when set, Kazma's agent commits as a bot)
# These env vars implicitly enable bot identity (overrides git.bot_identity in kazma.yaml)
# KAZMA_BOT_NAME=Kazma Agent
# KAZMA_BOT_EMAIL=kazma-agent[bot]@users.noreply.github.com
