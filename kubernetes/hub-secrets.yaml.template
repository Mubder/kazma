# Copy this file to hub-secrets.yaml and fill in real values.
# hub-secrets.yaml is gitignored (kubernetes/*secrets*.yaml) and must
# never be committed with real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: hub-secrets
  namespace: kazma
type: Opaque
stringData:
  database-url: "CHANGE_ME_DATABASE_URL/kazma_hub"
  redis-url: "redis://redis:6379/0"
